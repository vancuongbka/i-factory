{
  "name": "@i-factory/database",
  "version": "0.0.1",
  "private": true,
  "description": "TypeORM DataSource configuration and entity registry",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "typeorm migration:run -d src/data-source.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/data-source.ts",
    "db:migrate:generate": "typeorm migration:generate -d src/data-source.ts",
    "db:schema:drop": "typeorm schema:drop -d src/data-source.ts"
  },
  "dependencies": {
    "pg": "^8.12.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@i-factory/config": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.2.0"
  }
}
