{
  "name": "i-factory",
  "version": "0.0.1",
  "private": true,
  "description": "Hệ thống Quản lý Sản xuất (Manufacturing Execution System)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
