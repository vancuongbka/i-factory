{
  "name": "@i-factory/api",
  "version": "0.0.1",
  "private": true,
  "description": "i-factory NestJS REST API + WebSocket server",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "test:e2e": "jest --config test/jest-e2e.json",
    "typecheck": "tsc --noEmit",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d ../../packages/database/src/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d ../../packages/database/src/data-source.ts",
    "db:migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/Migration -d ../../packages/database/src/data-source.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seeds/run-seeds.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.6.0",
    "@bull-board/express": "^6.6.0",
    "@bull-board/nestjs": "^6.6.0",
    "@i-factory/api-types": "workspace:*",
    "@i-factory/database": "workspace:*",
    "@i-factory/utils": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-store": "^3.0.1",
    "dotenv": "^16.0.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@i-factory/config": "workspace:*",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  }
}
