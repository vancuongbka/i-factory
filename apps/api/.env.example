# =============================================================
# i-factory API — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# === App ===
NODE_ENV=development
PORT=3001

# === Database ===
DATABASE_URL=postgresql://ifactory:ifactory_dev@localhost:6000/ifactory
DATABASE_HOST=localhost
DATABASE_PORT=6000
DATABASE_NAME=ifactory
DATABASE_USER=ifactory
DATABASE_PASSWORD=ifactory_dev
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# === JWT ===
JWT_SECRET=change_me_in_production_must_be_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_in_production_must_be_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# === BullMQ / Bull Board ===
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=changeme

# === Multi-factory sync ===
FACTORY_SYNC_ENABLED=false
FACTORY_SYNC_INTERVAL_SECONDS=300

# === File uploads ===
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=10

# === CORS ===
CORS_ORIGINS=http://localhost:3000
